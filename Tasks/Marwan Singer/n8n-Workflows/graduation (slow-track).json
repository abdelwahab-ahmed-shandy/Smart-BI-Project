        "fromEmail": "marwansinger13579@gmail.com",
        "toEmail": "={{ $node[\"Webhook(Slow Track)\"].json.body.email }}",
        "subject": "المحلل الذكى",
        "html": "={{ (function() {\n  // 1. استخراج وتنظيف النص (الرؤية التحليلية)\n  const aiOutput = $json.final_report_text?.[0]?.output || \"لا توجد تحليلات متاحة حالياً.\";\n  \n  // تحويل النجوم لـ Bold بستايل أنيق وتنظيف السطور\n  const cleanInsight = aiOutput\n    .replace(/\\*\\*(.*?)\\*\\*/g, '<strong style=\"color: #059669; background: #ecfdf5; padding: 0 4px; border-radius: 4px;\">$1</strong>')\n    .replace(/\\n/g, '<br>');\n\n  // 2. جلب البيانات الرقمية\n  const totalSales = $json.totalSales || \"0\";\n  const ordersCount = $json.ordersCount || \"0\";\n  const topProduct = $json.topProduct || \"غير محدد\";\n  const top5Products = $json.top5Products || \"جاري التحليل...\";\n\n  return `\n  <div dir=\"rtl\" style=\"font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8fafc; padding: 40px 10px; color: #1e293b;\">\n      \n      <div style=\"max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 24px; overflow: hidden; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.04), 0 10px 10px -5px rgba(0,0,0,0.02); border: 1px solid #e2e8f0;\">\n          \n          <div style=\"background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); padding: 40px 20px; text-align: center; border-bottom: 5px solid #10b981;\">\n              <div style=\"background: rgba(16, 185, 129, 0.1); display: inline-block; padding: 6px 16px; border-radius: 50px; margin-bottom: 15px;\">\n                <span style=\"color: #10b981; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 2px;\">Smart Business Intelligence</span>\n              </div>\n              <h1 style=\"color: #ffffff; margin: 0; font-size: 28px; font-weight: 800;\">Data <span style=\"color: #10b981;\">Analysis</span></h1>\n              <p style=\"color: #94a3b8; margin-top: 10px; font-size: 14px; opacity: 0.9;\">تقرير الأداء الذكي • تحديث لحظي</p>\n          </div>\n\n          <div style=\"padding: 30px 25px;\">\n              <div style=\"background: linear-gradient(to left, #f8fafc, #ffffff); border-right: 4px solid #10b981; padding: 25px; border-radius: 16px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);\">\n                  <h3 style=\"color: #0f172a; margin: 0 0 15px 0; font-size: 17px; font-weight: 700; display: flex; align-items: center;\">\n                      <span style=\"font-size: 20px; margin-left: 10px;\">🧠</span> تحليل الذكاء الاصطناعي\n                  </h3>\n                  <div style=\"color: #475569; font-size: 15px; line-height: 1.9; text-align: justify; border-top: 1px solid #f1f5f9; padding-top: 15px;\">\n                      ${cleanInsight}\n                  </div>\n              </div>\n\n              <div style=\"text-align: center; margin-top: 40px; border-top: 1px solid #f1f5f9; padding-top: 20px;\">\n                  <p style=\"color: #94a3b8; font-size: 11px; margin: 0; letter-spacing: 1px;\">\n                    تم التوليد بواسطة AI ENGINE • ${new Date().toLocaleDateString('ar-EG')}\n                  </p>\n              </div>\n          </div>\n      </div>\n  </div>\n  `;\n})() }}",
