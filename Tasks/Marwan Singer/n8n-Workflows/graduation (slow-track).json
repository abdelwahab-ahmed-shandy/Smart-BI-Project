      "parameters": {
        "jsCode": "let summaryText = \"Sales Summary Report:\\n\";\n\nfor (const item of $input.all()) {\n  summaryText += `- ${item.json.Clean_Product} | Status: ${item.json.Clean_Status} | Source: ${item.json.Clean_Source} | Rev: $${item.json.sum_Clean_Price} | Qty: ${item.json.sum_Clean_Qty}\\n`;\n}\n\nreturn {\n  report_data: summaryText\n};"
