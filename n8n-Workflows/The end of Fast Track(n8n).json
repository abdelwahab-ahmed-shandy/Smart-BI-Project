    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet totalRevenue = 0;\nlet productCounts = {};\nlet hourlySales = {};\n\nitems.forEach(item => {\n    const data = item.json;\n    const price = parseFloat(data.UnitPrice || data.Price || 0);\n    const qty = parseInt(data.Quantity || data.Qty || 0);\n    const productName = data.Product || data.Item || \"Unknown\";\n    \n    totalRevenue += (price * qty);\n    productCounts[productName] = (productCounts[productName] || 0) + qty;\n\n    if (data.Date) {\n        // معالجة التاريخ لـ Excel (أرقام) أو نصوص\n        const dateObj = isNaN(data.Date) ? new Date(data.Date) : new Date((data.Date - 25569) * 86400 * 1000);\n        const hour = dateObj.getHours();\n        hourlySales[hour] = (hourlySales[hour] || 0) + 1;\n    }\n});\n\nconst sortedProducts = Object.entries(productCounts).sort((a, b) => b[1] - a[1]);\nconst top5 = sortedProducts.slice(0, 5).map(p => `${p[0]} (${p[1]} قطعة)`);\nconst bottom5 = sortedProducts.slice(-5).map(p => `${p[0]} (${p[1]} قطعة)`);\n\n// تحديد ساعة الذروة\nconst peakHour = Object.entries(hourlySales).sort((a, b) => b[1] - a[1])[0];\n\nreturn {\n    totalSales: totalRevenue.toLocaleString('en-US', { style: 'currency', currency: 'USD' }),\n    ordersCount: items.length,\n    topProduct: sortedProducts.length > 0 ? sortedProducts[0][0] : \"N/A\",\n    top5Products: top5.join(' | '),\n    bottom5Products: bottom5.join(' | '),\n    peakHour: peakHour ? `${peakHour[0]}:00` : \"غير محدد\",\n    // سحب الإيميل من النود الأولى بالاسم الجديد\n    userEmail: $node[\"Receive Sales File\"].json.body.email \n};"
      },
